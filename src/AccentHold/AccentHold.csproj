<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>AccentHold</AssemblyName>
    <RootNamespace>AccentHold</RootNamespace>
    <Version>1.0.0</Version>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <ApplicationIcon>Assets\icon.ico</ApplicationIcon>
    <Authors>Adrien Masanet</Authors>
    <Description>macOS-style press-and-hold accent picker for Windows</Description>
    <Copyright>© 2026 Adrien Masanet</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <!-- Keep WPF types unambiguous; WinForms/GDI are imported explicitly where needed. -->
    <Using Remove="System.Windows.Forms" />
    <Using Remove="System.Drawing" />
  </ItemGroup>

</Project>
